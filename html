        </div>
    </section>

    <!-- ABOUT -->
    <section class="about" id="o-nas">
        <div class="section-header fade-in">
            <span class="section-label">O nas</span>
            <h2 class="section-title">Bar MAXX Bistro</h2>
            <p class="section-subtitle">Miejsce, gdzie domowe jedzenie spotyka się z profesjonalną obsługą</p>
        </div>
